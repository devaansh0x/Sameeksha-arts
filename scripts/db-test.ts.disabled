/**
 * Database Connection Test Utility
 * 
 * This script tests the PostgreSQL database connection.
 * Run with: npx tsx lib/db-test.ts
 */

import { PrismaClient } from '@prisma/client';

const prisma = new PrismaClient({
    log: ['query', 'info', 'warn', 'error'],
});

async function testConnection() {
    console.log('Testing database connection...\n');

    try {
        // Test basic connection
        await prisma.$connect();
        console.log('✓ Successfully connected to database');

        // Test query execution
        const result = await prisma.$queryRaw`SELECT version()`;
        console.log('✓ Successfully executed test query');
        console.log('  PostgreSQL version:', result);

        // Check for tables
        const tables = await prisma.$queryRaw`
      SELECT tablename 
      FROM pg_tables 
      WHERE schemaname = 'public'
      ORDER BY tablename;
    `;
        console.log('\n✓ Database tables:');
        console.log(tables);

        // Count records in each table
        console.log('\n✓ Record counts:');
        const userCount = await prisma.user.count();
        const artworkCount = await prisma.artwork.count();
        const collectionCount = await prisma.collection.count();
        const mediaAssetCount = await prisma.mediaAsset.count();
        const recognitionCount = await prisma.recognition.count();
        const testimonialCount = await prisma.testimonial.count();
        const inquiryCount = await prisma.inquiry.count();
        const pageContentCount = await prisma.pageContent.count();

        console.log(`  Users: ${userCount}`);
        console.log(`  Artworks: ${artworkCount}`);
        console.log(`  Collections: ${collectionCount}`);
        console.log(`  Media Assets: ${mediaAssetCount}`);
        console.log(`  Recognition: ${recognitionCount}`);
        console.log(`  Testimonials: ${testimonialCount}`);
        console.log(`  Inquiries: ${inquiryCount}`);
        console.log(`  Page Content: ${pageContentCount}`);

        console.log('\n✅ Database connection test passed!');
        console.log('\nNext steps:');
        console.log('1. Run "npm run db:seed" to populate initial data');
        console.log('2. Run "npm run db:studio" to view data in Prisma Studio');
    } catch (error) {
        console.error('\n❌ Database connection test failed!');
        console.error('\nError details:', error);
        console.error('\nTroubleshooting:');
        console.error('1. Check that PostgreSQL is running');
        console.error('2. Verify DATABASE_URL in .env file');
        console.error('3. Ensure database exists');
        console.error('4. Run migrations: npm run db:migrate');
        process.exit(1);
    } finally {
        await prisma.$disconnect();
    }
}

testConnection();
