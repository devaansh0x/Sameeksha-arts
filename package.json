    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "postcss": "^8",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
